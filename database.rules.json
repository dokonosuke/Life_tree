{
  "rules": {
    "topics": {
      ".read": true,
      ".write": "auth != null"
    },
    "comments": {
      "$topicId": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    }
  }
}